{
  "name": "agentautopsy",
  "displayName": "AgentAutopsy — AI Agent Debugger",
  "description": "Debug AI agent failures with traces, root cause analysis, and auto-fix.",
  "version": "0.1.0",
  "publisher": "agentautopsy",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Debuggers",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:python"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "agentautopsy.startWatching",
        "title": "AgentAutopsy: Start Watching Agent"
      },
      {
        "command": "agentautopsy.showRuns",
        "title": "AgentAutopsy: Show Agent Runs"
      },
      {
        "command": "agentautopsy.fixRun",
        "title": "AgentAutopsy: Auto Fix This Run"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  }
}
